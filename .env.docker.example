# DMS Docker — variables d'environnement pour docker-compose
# Copier ce fichier et renseigner les valeurs reelles.
# Ce fichier est versionné ; les fichiers .env.* sont exclus du contexte de build Docker via .dockerignore.

# ── Base de donnees (deja defini dans docker-compose.yml, override ici si besoin) ──
# DATABASE_URL=postgresql+psycopg://dms:dms@postgres:5432/dms

# ── API principale ──
SECRET_KEY=dev-docker-compose-change-me
# JWT_SECRET=dev-jwt-change-me

# ── OCR / LLM ──
# MISTRAL_API_KEY=your-mistral-api-key
# LLAMADMS=llx-your-llama-cloud-api-key
# LLAMA_CLOUD_API_KEY=llx-your-llama-cloud-api-key

# ── LLM Arbitrator (M12) ──
# LLM_ARBITRATOR_ENABLED=true

# ── Annotation Backend ──
PSEUDONYM_SALT=dev-pseudonym-salt-change-me
# MISTRAL_MODEL=mistral-small-latest
# STRICT_PREDICT=0
# CORS_ORIGINS=http://localhost:8080

# ── Label Studio ──
# LABEL_STUDIO_URL=http://label-studio:8080
# LABEL_STUDIO_API_KEY=your-ls-token
# LABEL_STUDIO_PROJECT_ID=1
# LABEL_STUDIO_SSL_VERIFY=1

# ── R2 / S3 (corpus backup) ──
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL=
# R2_BUCKET_NAME=
