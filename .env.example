# DMS — ONLINE-ONLY (Constitution V2.1)
# No SQLite fallback. DATABASE_URL is required.

# PostgreSQL (required)
# Railway: Add PostgreSQL plugin → DATABASE_URL auto-injected
# Render: Add PostgreSQL → DATABASE_URL auto-injected
# Local Docker:
#   docker run -d -p 5432:5432 -e POSTGRES_USER=dms -e POSTGRES_PASSWORD=dms -e POSTGRES_DB=dms postgres:16
#   DATABASE_URL=postgresql+psycopg://dms:dms@localhost:5432/dms

DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# Optional: port for local dev (Railway uses $PORT)
# PORT=5000

# ── External AI / OCR APIs ─────────────────────────────────────────────────
# LlamaParse (llama-cloud) — PDF / offres / DAO (extract_text_any, engine SLA-B)
# Get your key at https://cloud.llamaindex.ai/
# LlamaParse : définir LLAMADMS (prioritaire) et/ou LLAMA_CLOUD_API_KEY (alias LlamaIndex).
LLAMADMS=llx-your-llama-cloud-api-key-here
# LLAMA_CLOUD_API_KEY=llx-your-llama-cloud-api-key-here

# Mistral AI — required only when llm_provider=mistral or extraction_method=mistral_ocr
# Get your key at https://console.mistral.ai/
MISTRAL_API_KEY=your-mistral-api-key-here

# ── Label Studio (scripts locaux : export LS, autosave, backfill) ──────────
# Ne jamais committer de vraies valeurs : utiliser .env.local (gitignoré).
# Jeton : PAT → rafraîchir puis envoyer en Authorization: Bearer (voir E-68 / ls_client).
# LABEL_STUDIO_URL=https://your-label-studio.example
# LABEL_STUDIO_API_KEY=your-ls-personal-access-token
# LABEL_STUDIO_PROJECT_ID=1
# Alias acceptés par plusieurs scripts : LS_URL, LS_API_KEY
# TLS/proxy d’entreprise uniquement si nécessaire :
# LABEL_STUDIO_SSL_VERIFY=0
# LABEL_STUDIO_LEGACY_TOKEN=1
