# Local development — copy to .env.local and adjust
# cp .env.local.example .env.local

# Database — canonical URL when using repo docker-compose (service postgres: user dms, db dms)
# docker compose up -d postgres  →  use this line as-is for localhost:
DATABASE_URL=postgresql+psycopg://dms:dms@localhost:5432/dms

# If you use a native PostgreSQL install instead of Compose, set DATABASE_URL to match
# THAT instance (user/password/database you created). Do not mix with the dms URL above.
# Example only (not the Compose default): postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/your_db

# ── External AI / OCR APIs ─────────────────────────────────────────────────
# Uncomment and fill in to enable LlamaParse / Mistral features locally.
# LLAMADMS=llx-...                    # prioritaire (même convention que Railway)
# LLAMA_CLOUD_API_KEY=llx-...        # alias si pas de LLAMADMS
# MISTRAL_API_KEY=sk-...REPLACE_ME...   # jamais de vraie clé dans un fichier versionné
#
# LlamaCloud (mercuriale) : par défaut la vérification TLS du client httpx est activée.
# Derrière un proxy d’entreprise qui casse les certificats uniquement :
# LLAMACLOUD_HTTPX_VERIFY_SSL=0

# ── Accès workspace (pilote / tests terrain) ───────────────────────────────
# Par défaut l’API exige ``workspace_memberships`` ou RBAC tenant ``workspace.read``.
# Pour un déploiement pilote sans provisioning memberships : ``true`` puis REBUILD API.
# À remettre ``false`` (ou unset) avant prod « prête » (gouvernance memberships).
# WORKSPACE_ACCESS_JWT_FALLBACK=true
# (alias Railway : DMS_WORKSPACE_ACCESS_JWT_FALLBACK=true)

# ── Label Studio (local — gitignoré une fois copié en .env.local) ────────────
# LABEL_STUDIO_URL=https://...
# LABEL_STUDIO_API_KEY=...
# LABEL_STUDIO_PROJECT_ID=1
# LABEL_STUDIO_SSL_VERIFY=0
# LS_URL=...          # alias
# LS_API_KEY=...      # alias
