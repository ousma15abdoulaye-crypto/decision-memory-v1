# Local development — copy to .env.local and adjust
# cp .env.local.example .env.local

# Database (adjust to your local PostgreSQL)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/decision_memory_dev

# ── External AI / OCR APIs ─────────────────────────────────────────────────
# Uncomment and fill in to enable LlamaParse / Mistral features locally.
# LLAMADMS=llx-...                    # prioritaire (même convention que Railway)
# LLAMA_CLOUD_API_KEY=llx-...        # alias si pas de LLAMADMS
# MISTRAL_API_KEY=your-mistral-api-key-here
