# frontend-v51 — environment variables
# Copy to .env.local for local development (never commit .env.local)
# cp .env.example .env.local

# ── API backend ────────────────────────────────────────────────────────────
# URL of the DMS FastAPI backend. Must be set at BUILD TIME for Next.js to
# embed the value in the client bundle (NEXT_PUBLIC_ prefix).
#
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:8000
#
# Production (Railway):
# NEXT_PUBLIC_API_URL=https://decision-memory-v1-production.up.railway.app:8080
