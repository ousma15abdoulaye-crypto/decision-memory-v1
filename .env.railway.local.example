# Copier ce fichier vers .env.railway.local (non versionné) et remplir les valeurs.
# Ne jamais committer .env.railway.local — voir docs/ops/RAILWAY_LOCAL_ENV.md
#
# URL PostgreSQL Railway — réseau PUBLIC (proxy *.proxy.rlwy.net), pas postgres.railway.internal.
# Format accepté : postgresql:// ou postgresql+psycopg://
RAILWAY_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/railway

# Optionnel — seulement si tu utilises railway CLI en non-interactif (éviter de stocker si possible)
# RAILWAY_TOKEN=
