{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.dms-db-worker"
  },
  "deploy": {
    "startCommand": "cd services/worker-railway && uvicorn main:app --host 0.0.0.0 --port ${PORT}",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 30
  }
}
