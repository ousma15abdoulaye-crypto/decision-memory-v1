<View>
  <Style>
    .main  { max-width: 1400px; margin: 0 auto; overflow: hidden; }
    .left  { width: 48%; float: left;  padding: 10px;
             border-right: 2px solid #ddd; box-sizing: border-box; }
    .right { width: 48%; float: right; padding: 10px;
             box-sizing: border-box; }
    .label { font-weight: bold; margin-top: 12px;
             display: block; color: #333; }
  </Style>

  <View className="main">
    <!-- PANNEAU GAUCHE — texte source -->
    <View className="left">
      <Header value="Document source — texte extrait"/>
      <Text name="document_text" value="$text"/>
    </View>

    <!-- PANNEAU DROIT — review Mistral -->
    <View className="right">

      <Header value="0 — Doctrine evidence (obligatoire avant VALIDÉ)"/>
      <Choices
        name="evidence_attestation"
        toName="document_text"
        choice="single"
        showInLine="false"
        required="true">
        <Choice value="confirmed_from_doc"
                label="Je confirme : chaque valeur non-ABSENT du JSON a une evidence issue du document (citer page/section dans le champ evidence du JSON)."/>
        <Choice value="corrected_in_json"
                label="J'ai corrigé le JSON pour aligner evidence et texte source."/>
      </Choices>
      <Choices
        name="no_invented_numbers"
        toName="document_text"
        choice="single"
        showInLine="false"
        required="true">
        <Choice value="confirmed"
                label="Aucun montant / quantité inventé : tout provient du texte affiché à gauche."/>
        <Choice value="corrected"
                label="J'ai corrigé des chiffres dans le JSON pour correspondre au document."/>
      </Choices>

      <Header value="1 — JSON extrait par Mistral — corriger si nécessaire"/>
      <TextArea
        name="extracted_json"
        toName="document_text"
        placeholder="JSON Mistral — éditable"
        rows="28"
        editable="true"/>

      <Header value="2 — Type de document détecté (taxonomy_core)"/>
      <Choices
        name="routing_ok"
        toName="document_text"
        choice="single"
        showInLine="false"
        required="true">
        <Choice value="correct"
                label="✓ Routing correct — taxonomy_core conforme"/>
        <Choice value="corrected"
                label="✗ Routing corrigé dans le JSON ci-dessus"/>
        <Choice value="not_applicable"
                label="N/A — classification taxonomy non applicable"/>
      </Choices>

      <Header value="3 — Champs financiers (total_price + line_items)"/>
      <Choices
        name="financial_ok"
        toName="document_text"
        choice="single"
        showInLine="false"
        required="true">
        <Choice value="correct"
                label="✓ Montants et lignes corrects"/>
        <Choice value="corrected"
                label="✗ Corrigé dans le JSON ci-dessus"/>
        <Choice value="not_applicable"
                label="N/A — pas une offre financière"/>
      </Choices>

      <Header value="4 — Notes correcteur (AMBIG · doutes · décisions)"/>
      <TextArea
        name="annotation_notes"
        toName="document_text"
        placeholder="Ex: taxonomy_core corrigé · RIB evidence tronquée · budget détaillé niveau récap retenu"
        rows="4"/>

      <Header value="5 — Statut final OBLIGATOIRE"/>
      <Choices
        name="annotation_status"
        toName="document_text"
        choice="single"
        required="true"
        showInLine="false">
        <Choice value="annotated_validated"
                label="✓ VALIDÉ — comptable M12"/>
        <Choice value="review_required"
                label="⚠ À REPASSER"/>
        <Choice value="rejected"
                label="✗ REJETÉ"/>
      </Choices>

    </View>
  </View>
</View>
