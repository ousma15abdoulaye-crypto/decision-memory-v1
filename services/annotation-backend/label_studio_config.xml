<View>
  <Style>
    .main  { max-width: 1400px; margin: 0 auto; }
    .left  { width: 48%; float: left;  padding: 10px;
             border-right: 2px solid #ddd; }
    .right { width: 48%; float: right; padding: 10px; }
    .label { font-weight: bold; margin-top: 12px;
             display: block; color: #333; }
  </Style>

  <!-- PANNEAU GAUCHE — texte source -->
  <View className="left">
    <Header value="Document source — texte extrait"/>
    <Text name="document_text" value="$text"/>
  </View>

  <!-- PANNEAU DROIT — review Mistral -->
  <View className="right">

    <Header value="1 — JSON extrait par Mistral — corriger si nécessaire"/>
    <TextArea
      name="extracted_json"
      toName="document_text"
      placeholder="JSON Mistral — éditable"
      rows="28"
      editable="true"/>

    <Header value="2 — Type de document détecté (taxonomy_core)"/>
    <Choices
      name="routing_ok"
      toName="document_text"
      choice="single"
      showInLine="false"
      required="true">
      <Choice value="correct"
              label="✓ Routing correct — taxonomy_core conforme"/>
      <Choice value="corrected"
              label="✗ Routing corrigé dans le JSON ci-dessus"/>
    </Choices>

    <Header value="3 — Champs financiers (total_price + line_items)"/>
    <Choices
      name="financial_ok"
      toName="document_text"
      choice="single"
      showInLine="false"
      required="true">
      <Choice value="correct"
              label="✓ Montants et lignes corrects"/>
      <Choice value="corrected"
              label="✗ Corrigé dans le JSON ci-dessus"/>
      <Choice value="not_applicable"
              label="N/A — pas une offre financière"/>
    </Choices>

    <Header value="4 — Notes correcteur (AMBIG · doutes · décisions)"/>
    <TextArea
      name="annotation_notes"
      toName="document_text"
      placeholder="Ex: taxonomy_core corrigé · RIB evidence tronquée · budget détaillé niveau récap retenu"
      rows="4"/>

    <Header value="5 — Statut final OBLIGATOIRE"/>
    <Choices
      name="annotation_status"
      toName="document_text"
      choice="single"
      required="true"
      showInLine="false">
      <Choice value="annotated_validated"
              label="✓ VALIDÉ — comptable M12"/>
      <Choice value="review_required"
              label="⚠ À REPASSER"/>
      <Choice value="rejected"
              label="✗ REJETÉ"/>
    </Choices>

  </View>
</View>
